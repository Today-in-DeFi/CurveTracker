# Google Sheets Configuration
# Path to your Google service account credentials JSON file
GOOGLE_CREDENTIALS_FILE=./Google Credentials.json

# Optional: Default spreadsheet ID (can be overridden with --sheet-id)
# GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Optional: Default spreadsheet name (can be overridden with --sheet-name)
# GOOGLE_SPREADSHEET_NAME=Curve Pool Tracker

# Optional: Ethereum RPC for reading gauge reward expiry (period_finish).
# Tried first, with public endpoints as fallback. Disable the reads entirely
# with --no-gauge-rpc.
# ETHEREUM_RPC_URL=https://your-provider/v2/your-key

# Optional: path to PegTracker's latest USD feed, used to price non-$1 tokens
# (e.g. sUSDe) in Plasma/Monad pool TVL. Defaults to a sibling PegTracker
# checkout: ../PegTracker/data/peg_tracker_latest_usd.json
# PEGTRACKER_USD_FEED=/home/danger/PegTracker/data/peg_tracker_latest_usd.json